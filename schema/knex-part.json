{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "K'Nex Part Definition",
  "description": "Complete metadata for any K'Nex piece (connector, rod, wheel, etc.)",
  "type": "object",
  "required": ["id", "name", "category", "mesh_file", "ports"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique machine-friendly ID, e.g. 'connector-3way-yellow-v1'"
    },
    "name": {
      "type": "string",
      "description": "Human-readable name"
    },
    "category": {
      "enum": ["connector", "rod", "wheel", "plate", "special"],
      "description": "Used for palette grouping and AI part vocabulary"
    },
    "mesh_file": {
      "type": "string",
      "description": "Relative path to GLTF/GLB (e.g. 'meshes/connector-3way-yellow.glb')"
    },
    "default_color": {
      "type": "string",
      "format": "color",
      "description": "Hex color for default rendering"
    },
    "mass_grams": {
      "type": "number",
      "minimum": 0
    },
    "ports": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "position", "direction", "mate_type"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique within this part, e.g. 'A', 'B', 'C', 'end1'"
          },
          "position": {
            "type": "array",
            "items": { "type": "number" },
            "minItems": 3,
            "maxItems": 3,
            "description": "Relative XYZ in part-local units (same scale as mesh)"
          },
          "direction": {
            "type": "array",
            "items": { "type": "number" },
            "minItems": 3,
            "maxItems": 3,
            "description": "Unit vector pointing OUT from the part (insertion direction for rods)"
          },
          "mate_type": {
            "enum": ["rod_hole", "rod_end", "tab", "clip"],
            "description": "What this port accepts or provides"
          },
          "accepts": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Optional list of compatible mate_types from other parts"
          },
          "allowed_angles_deg": {
            "type": "array",
            "items": { "type": "number" },
            "description": "Allowed rotation steps around the direction axis (e.g. [0, 90, 180, 270])"
          },
          "tolerance_mm": {
            "type": "number",
            "default": 0.2
          }
        }
      }
    }
  },
  "additionalProperties": false
}